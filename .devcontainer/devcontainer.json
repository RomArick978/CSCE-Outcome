{
  "name": "Vibe Hackathon Dev Environment",
  
  "customizations": {
    "vscode": {
      "extensions": [
        // ✨ Auto-formatting - Makes your code look pretty automatically
        "esbenp.prettier-vscode",
        
        // 🔴 Error Lens - Shows errors right in the code (very visual!)
        "usernamehv.errorlens",
        
        // 🐳 Docker - Helps with containers
        "ms-azuretools.vscode-docker",
        
        // 📁 Better file icons
        "vscode-icons-team.vscode-icons",

        // 🤖 Cline AI coding assistant
        "saoudrizwan.claude-dev"
      ],
      
      "settings": {
        // === AUTO-FORMAT ON SAVE (no action needed!) ===
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        
        // === VISUAL HELPERS ===
        "editor.bracketPairColorization.enabled": true,
        "editor.guides.bracketPairs": true,
        "editor.minimap.enabled": false,
        "editor.wordWrap": "on",
        
        // === ERROR LENS (shows errors inline) ===
        "errorLens.enabledDiagnosticLevels": ["error", "warning"],
        "errorLens.messageMaxChars": 100,
        
        // === TERMINAL ===
        "terminal.integrated.defaultProfile.linux": "bash",
        
        // === FILES ===
        "files.autoSave": "afterDelay",
        "files.autoSaveDelay": 1000,
        "explorer.confirmDelete": false
      }
    }
  },

  "onCreateCommand": "bash .devcontainer/install-cline.sh",
  "postStartCommand": "bash .devcontainer/auto-update-template.sh; bash scripts/install-hooks.sh; rm -f backend/env.example database/env.example database/.env.example vectordb/env.example",

  "forwardPorts": [3000, 5050, 5173, 8080, 8888],

  "portsAttributes": {
    "8888": { "label": "Chat UI", "onAutoForward": "openBrowser" },
    "5050": { "label": "Runner API", "onAutoForward": "silent" }
  }
}
